{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.tickerdb/mcp-server",
  "title": "TickerDB",
  "description": "Pre-computed financial market intelligence for AI agents. Stocks, crypto, and ETFs.",
  "version": "1.7.2",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.tickerdb.com/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "tickerdb-mcp",
      "version": "1.7.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TICKERDB_KEY",
          "description": "Your TickerDB API key (get one at tickerdb.com/dashboard)",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/tickerdb/tickerdb-mcp",
    "source": "github"
  }
}
