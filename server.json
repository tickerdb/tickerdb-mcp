{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.tickerapi/mcp-server",
  "title": "TickerAPI",
  "description": "Pre-computed financial market intelligence for AI agents. Stocks, crypto, and ETFs.",
  "version": "1.5.2",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.tickerapi.ai/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "tickerapi-mcp-server",
      "version": "1.5.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TICKERAPI_KEY",
          "description": "Your TickerAPI API key (get one at tickerapi.ai/dashboard)",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/TickerAPI/tickerapi-mcp",
    "source": "github"
  }
}
